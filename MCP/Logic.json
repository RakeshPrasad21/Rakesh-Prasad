{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "logicAppName": {
      "type": "string",
      "defaultValue": "MSEM-Identity-Dashboard-Automation",
      "metadata": {
        "description": "Name of the Logic App"
      }
    },
    "logicAppLocation": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for the Logic App"
      }
    },
    "recurrenceTime": {
      "type": "string",
      "defaultValue": "08:00:00",
      "metadata": {
        "description": "Time to run daily (HH:mm:ss format, 24-hour)"
      }
    },
    "timeZone": {
      "type": "string",
      "defaultValue": "Eastern Standard Time",
      "metadata": {
        "description": "Time zone for the recurrence schedule"
      }
    },
    "teamsConnectionName": {
      "type": "string",
      "defaultValue": "teams",
      "metadata": {
        "description": "Name of the Teams API connection"
      }
    },
    "office365ConnectionName": {
      "type": "string",
      "defaultValue": "office365",
      "metadata": {
        "description": "Name of the Office 365 Outlook API connection"
      }
    },
    "emailRecipients": {
      "type": "string",
      "defaultValue": "security-team@yourdomain.com",
      "metadata": {
        "description": "Semicolon-separated list of email recipients"
      }
    }
  },
  "variables": {},
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[parameters('teamsConnectionName')]",
      "location": "[parameters('logicAppLocation')]",
      "properties": {
        "displayName": "Teams Connection for MSEM Dashboard",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('logicAppLocation'), '/managedApis/teams')]"
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[parameters('office365ConnectionName')]",
      "location": "[parameters('logicAppLocation')]",
      "properties": {
        "displayName": "Office 365 Outlook Connection for MSEM Dashboard",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('logicAppLocation'), '/managedApis/office365')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('logicAppName')]",
      "location": "[parameters('logicAppLocation')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "defaultValue": {},
              "type": "Object"
            }
          },
          "triggers": {
            "Recurrence": {
              "recurrence": {
                "frequency": "Day",
                "interval": 1,
                "schedule": {
                  "hours": ["[split(parameters('recurrenceTime'), ':')[0]]"],
                  "minutes": ["[split(parameters('recurrenceTime'), ':')[1]]"]
                },
                "timeZone": "[parameters('timeZone')]"
              },
              "type": "Recurrence"
            }
          },
          "actions": {
            "Get_Current_SecureScore": {
              "runAfter": {},
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "https://graph.microsoft.com/v1.0/security/secureScores?$top=1",
                "authentication": {
                  "type": "ManagedServiceIdentity",
                  "audience": "https://graph.microsoft.com"
                }
              }
            },
            "Parse_SecureScore": {
              "runAfter": {
                "Get_Current_SecureScore": ["Succeeded"]
              },
              "type": "ParseJson",
              "inputs": {
                "content": "@body('Get_Current_SecureScore')",
                "schema": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "string"},
                          "createdDateTime": {"type": "string"},
                          "currentScore": {"type": "number"},
                          "maxScore": {"type": "number"},
                          "averageComparativeScores": {"type": "array"},
                          "controlScores": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "controlCategory": {"type": "string"},
                                "controlName": {"type": "string"},
                                "description": {"type": "string"},
                                "score": {"type": "number"}
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "Filter_Identity_Controls": {
              "runAfter": {
                "Parse_SecureScore": ["Succeeded"]
              },
              "type": "Query",
              "inputs": {
                "from": "@body('Parse_SecureScore')?['value']?[0]?['controlScores']",
                "where": "@equals(item()?['controlCategory'], 'Identity')"
              }
            },
            "Initialize_Identity_Current_Score_Var": {
              "runAfter": {
                "Filter_Identity_Controls": ["Succeeded"]
              },
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "IdentityCurrentScore",
                    "type": "float",
                    "value": 0
                  }
                ]
              }
            },
            "Loop_Current_Identity_Scores": {
              "runAfter": {
                "Initialize_Identity_Current_Score_Var": ["Succeeded"]
              },
              "type": "Foreach",
              "foreach": "@body('Filter_Identity_Controls')",
              "actions": {
                "Accumulate_Current_Score": {
                  "type": "IncrementVariable",
                  "inputs": {
                    "name": "IdentityCurrentScore",
                    "value": "@item()?['score']"
                  }
                }
              }
            },
            "Calculate_Identity_Current_Score": {
              "runAfter": {
                "Loop_Current_Identity_Scores": ["Succeeded"]
              },
              "type": "Compose",
              "inputs": "@variables('IdentityCurrentScore')"
            },
            "Calculate_Score_Percentage": {
              "runAfter": {
                "Calculate_Identity_Current_Score": ["Succeeded"]
              },
              "type": "Compose",
              "inputs": "@mul(div(body('Parse_SecureScore')?['value']?[0]?['currentScore'], body('Parse_SecureScore')?['value']?[0]?['maxScore']), 100)"
            },
            "Get_Historical_SecureScores": {
              "runAfter": {
                "Calculate_Score_Percentage": ["Succeeded"]
              },
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "https://graph.microsoft.com/v1.0/security/secureScores?$top=10",
                "authentication": {
                  "type": "ManagedServiceIdentity",
                  "audience": "https://graph.microsoft.com"
                }
              }
            },
            "Parse_Historical_SecureScores": {
              "runAfter": {
                "Get_Historical_SecureScores": ["Succeeded"]
              },
              "type": "ParseJson",
              "inputs": {
                "content": "@body('Get_Historical_SecureScores')",
                "schema": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "currentScore": {"type": "number"},
                          "controlScores": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "controlCategory": {"type": "string"},
                                "score": {"type": "number"}
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "Initialize_Identity_Previous_Score_Var": {
              "runAfter": {
                "Parse_Historical_SecureScores": ["Succeeded"]
              },
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "IdentityPreviousScore",
                    "type": "float",
                    "value": 0
                  }
                ]
              }
            },
            "Initialize_Previous_Score_Found_Flag": {
              "runAfter": {
                "Initialize_Identity_Previous_Score_Var": ["Succeeded"]
              },
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "PreviousScoreFound",
                    "type": "boolean",
                    "value": false
                  }
                ]
              }
            },
            "Initialize_Temp_Historical_Score": {
              "runAfter": {
                "Initialize_Previous_Score_Found_Flag": ["Succeeded"]
              },
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "TempHistoricalScore",
                    "type": "float",
                    "value": 0
                  }
                ]
              }
            },
            "Loop_Historical_Scores_To_Find_Change": {
              "runAfter": {
                "Initialize_Temp_Historical_Score": ["Succeeded"]
              },
              "type": "Foreach",
              "foreach": "@skip(body('Parse_Historical_SecureScores')?['value'], 1)",
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 1
                }
              },
              "actions": {
                "Check_If_Previous_Score_Already_Found": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "equals": [
                          "@variables('PreviousScoreFound')",
                          false
                        ]
                      }
                    ]
                  },
                  "actions": {
                    "Filter_Historical_Identity_Controls": {
                      "type": "Query",
                      "inputs": {
                        "from": "@item()?['controlScores']",
                        "where": "@equals(item()?['controlCategory'], 'Identity')"
                      }
                    },
                    "Reset_Temp_Historical_Score": {
                      "runAfter": {
                        "Filter_Historical_Identity_Controls": ["Succeeded"]
                      },
                      "type": "SetVariable",
                      "inputs": {
                        "name": "TempHistoricalScore",
                        "value": 0
                      }
                    },
                    "Loop_Historical_Identity_Scores": {
                      "runAfter": {
                        "Reset_Temp_Historical_Score": ["Succeeded"]
                      },
                      "type": "Foreach",
                      "foreach": "@body('Filter_Historical_Identity_Controls')",
                      "actions": {
                        "Accumulate_Temp_Score": {
                          "type": "IncrementVariable",
                          "inputs": {
                            "name": "TempHistoricalScore",
                            "value": "@item()?['score']"
                          }
                        }
                      }
                    },
                    "Check_If_Score_Different_From_Current": {
                      "runAfter": {
                        "Loop_Historical_Identity_Scores": ["Succeeded"]
                      },
                      "type": "If",
                      "expression": {
                        "and": [
                          {
                            "not": {
                              "equals": [
                                "@variables('TempHistoricalScore')",
                                "@outputs('Calculate_Identity_Current_Score')"
                              ]
                            }
                          }
                        ]
                      },
                      "actions": {
                        "Set_Previous_Score": {
                          "type": "SetVariable",
                          "inputs": {
                            "name": "IdentityPreviousScore",
                            "value": "@variables('TempHistoricalScore')"
                          }
                        },
                        "Set_Found_Flag": {
                          "runAfter": {
                            "Set_Previous_Score": ["Succeeded"]
                          },
                          "type": "SetVariable",
                          "inputs": {
                            "name": "PreviousScoreFound",
                            "value": true
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "Set_Previous_Score_To_Current_If_Not_Found": {
              "runAfter": {
                "Loop_Historical_Scores_To_Find_Change": ["Succeeded"]
              },
              "type": "If",
              "expression": {
                "and": [
                  {
                    "equals": [
                      "@variables('PreviousScoreFound')",
                      false
                    ]
                  }
                ]
              },
              "actions": {
                "Set_Previous_To_Current": {
                  "type": "SetVariable",
                  "inputs": {
                    "name": "IdentityPreviousScore",
                    "value": "@outputs('Calculate_Identity_Current_Score')"
                  }
                }
              }
            },
            "Initialize_ScoreChange": {
              "runAfter": {
                "Set_Previous_Score_To_Current_If_Not_Found": ["Succeeded"]
              },
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "ScoreChange",
                    "type": "float",
                    "value": "@sub(outputs('Calculate_Identity_Current_Score'), variables('IdentityPreviousScore'))"
                  }
                ]
              }
            },
            "Initialize_Identity_Score_Percentage_Change": {
              "runAfter": {
                "Initialize_ScoreChange": ["Succeeded"]
              },
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "IdentityScorePercentageChange",
                    "type": "float",
                    "value": "@if(greater(variables('IdentityPreviousScore'), 0), mul(div(sub(outputs('Calculate_Identity_Current_Score'), variables('IdentityPreviousScore')), variables('IdentityPreviousScore')), 100), 0)"
                  }
                ]
              }
            },
            "Get_Recommendations": {
              "runAfter": {
                "Initialize_Identity_Score_Percentage_Change": ["Succeeded"]
              },
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "https://graph.microsoft.com/v1.0/security/secureScoreControlProfiles?$filter=controlCategory%20eq%20'Identity'&$orderby=rank%20asc&$top=10",
                "authentication": {
                  "type": "ManagedServiceIdentity",
                  "audience": "https://graph.microsoft.com"
                }
              }
            },
            "Parse_Recommendations": {
              "runAfter": {
                "Get_Recommendations": ["Succeeded"]
              },
              "type": "ParseJson",
              "inputs": {
                "content": "@body('Get_Recommendations')",
                "schema": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "string"},
                          "title": {"type": "string"},
                          "rank": {"type": "integer"},
                          "maxScore": {"type": "number"},
                          "implementationCost": {"type": "string"},
                          "userImpact": {"type": ["string", "null"]},
                          "deprecated": {"type": "boolean"},
                          "controlCategory": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "Query_HighRisk_Identities": {
              "runAfter": {
                "Parse_Recommendations": ["Succeeded"]
              },
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.security.microsoft.com/api/advancedhunting/run",
                "headers": {
                  "Content-Type": "application/json"
                },
                "body": {
                  "Query": "ExposureGraphNodes | where NodeLabel in ('user', 'serviceprincipal', 'manageidentity') | extend exposureScore = tostring(NodeProperties.rawData.exposureScore) | where exposureScore in ('High', 'Medium') | summarize HighRisk=count(), Critical=countif(exposureScore == 'High'), HighCount=countif(exposureScore == 'High'), MediumCount=countif(exposureScore == 'Medium')"
                },
                "authentication": {
                  "type": "ManagedServiceIdentity",
                  "audience": "https://api.security.microsoft.com"
                }
              }
            },
            "Parse_HighRiskIdentities": {
              "runAfter": {
                "Query_HighRisk_Identities": ["Succeeded"]
              },
              "type": "ParseJson",
              "inputs": {
                "content": "@body('Query_HighRisk_Identities')",
                "schema": {
                  "type": "object",
                  "properties": {
                    "Schema": {"type": "array"},
                    "Results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "HighRisk": {"type": "integer"},
                          "Critical": {"type": "integer"},
                          "HighCount": {"type": "integer"},
                          "MediumCount": {"type": "integer"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "Query_Privileged_Accounts": {
              "runAfter": {
                "Parse_HighRiskIdentities": ["Succeeded"]
              },
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.security.microsoft.com/api/advancedhunting/run",
                "headers": {
                  "Content-Type": "application/json"
                },
                "body": {
                  "Query": "ExposureGraphNodes | where NodeLabel in ('serviceprincipal', 'manageidentity', 'user') | extend criticalityLevel = tostring(NodeProperties.rawData.criticalityLevel.criticalityLevel), lastSeen = todatetime(NodeProperties.rawData.lastSeen) | where isnotempty(criticalityLevel) | extend DaysSinceLastSeen = datetime_diff('day', now(), lastSeen) | summarize Total=count(), Active=countif(DaysSinceLastSeen < 30), Idle=countif(DaysSinceLastSeen >= 30 and DaysSinceLastSeen <= 90), Dormant=countif(DaysSinceLastSeen > 90 or isnull(DaysSinceLastSeen))"
                },
                "authentication": {
                  "type": "ManagedServiceIdentity",
                  "audience": "https://api.security.microsoft.com"
                }
              }
            },
            "Parse_PrivilegedAccounts": {
              "runAfter": {
                "Query_Privileged_Accounts": ["Succeeded"]
              },
              "type": "ParseJson",
              "inputs": {
                "content": "@body('Query_Privileged_Accounts')",
                "schema": {
                  "type": "object",
                  "properties": {
                    "Schema": {"type": "array"},
                    "Results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Total": {"type": "integer"},
                          "Active": {"type": "integer"},
                          "Idle": {"type": "integer"},
                          "Dormant": {"type": "integer"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "Query_MFA_Status": {
              "runAfter": {
                "Parse_PrivilegedAccounts": ["Succeeded"]
              },
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.security.microsoft.com/api/advancedhunting/run",
                "headers": {
                  "Content-Type": "application/json"
                },
                "body": {
                  "Query": "ExposureGraphNodes | where NodeLabel in ('user', 'serviceprincipal', 'manageidentity') | extend exposureScore = tostring(NodeProperties.rawData.exposureScore) | summarize Total=count(), HighExposure=countif(exposureScore == 'High'), MediumExposure=countif(exposureScore == 'Medium'), LowOrNone=countif(exposureScore in ('Low', 'None')) | extend SecureRate=round(todouble(LowOrNone) / todouble(Total) * 100, 2)"
                },
                "authentication": {
                  "type": "ManagedServiceIdentity",
                  "audience": "https://api.security.microsoft.com"
                }
              }
            },
            "Parse_MFAStatus": {
              "runAfter": {
                "Query_MFA_Status": ["Succeeded"]
              },
              "type": "ParseJson",
              "inputs": {
                "content": "@body('Query_MFA_Status')",
                "schema": {
                  "type": "object",
                  "properties": {
                    "Schema": {"type": "array"},
                    "Results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Total": {"type": "integer"},
                          "HighExposure": {"type": "integer"},
                          "MediumExposure": {"type": "integer"},
                          "LowOrNone": {"type": "integer"},
                          "SecureRate": {"type": ["number", "string"]}
                        }
                      }
                    }
                  }
                }
              }
            },
            "Compose_Final_Metrics": {
              "runAfter": {
                "Parse_MFAStatus": ["Succeeded"]
              },
              "type": "Compose",
              "inputs": {
                "Timestamp": "@utcNow()",
                "SecureScore": {
                  "Overall_Current": "@body('Parse_SecureScore')?['value']?[0]?['currentScore']",
                  "Overall_Max": "@body('Parse_SecureScore')?['value']?[0]?['maxScore']",
                  "Overall_Percentage": "@outputs('Calculate_Score_Percentage')",
                  "Identity_Current": "@outputs('Calculate_Identity_Current_Score')",
                  "Identity_Previous": "@variables('IdentityPreviousScore')",
                  "Identity_Change_Points": "@variables('ScoreChange')",
                  "Identity_Change_Percentage": "@variables('IdentityScorePercentageChange')",
                  "Previous_Score_Found": "@variables('PreviousScoreFound')"
                },
                "RiskSummary": {
                  "HighRiskIdentities": "@body('Parse_HighRiskIdentities')?['Results']?[0]?['HighRisk']",
                  "CriticalIdentities": "@body('Parse_HighRiskIdentities')?['Results']?[0]?['Critical']",
                  "HighExposureCount": "@body('Parse_HighRiskIdentities')?['Results']?[0]?['HighCount']",
                  "MediumExposureCount": "@body('Parse_HighRiskIdentities')?['Results']?[0]?['MediumCount']"
                },
                "PrivilegedAccounts": {
                  "Total": "@body('Parse_PrivilegedAccounts')?['Results']?[0]?['Total']",
                  "Active": "@body('Parse_PrivilegedAccounts')?['Results']?[0]?['Active']",
                  "Idle": "@body('Parse_PrivilegedAccounts')?['Results']?[0]?['Idle']",
                  "Dormant": "@body('Parse_PrivilegedAccounts')?['Results']?[0]?['Dormant']"
                },
                "MFAStatus": {
                  "Total": "@body('Parse_MFAStatus')?['Results']?[0]?['Total']",
                  "HighExposure": "@body('Parse_MFAStatus')?['Results']?[0]?['HighExposure']",
                  "MediumExposure": "@body('Parse_MFAStatus')?['Results']?[0]?['MediumExposure']",
                  "LowOrNone": "@body('Parse_MFAStatus')?['Results']?[0]?['LowOrNone']",
                  "SecureRate": "@body('Parse_MFAStatus')?['Results']?[0]?['SecureRate']"
                },
                "TopRecommendations": "@take(body('Parse_Recommendations')?['value'], 3)"
              }
            },
            "Compose_TeamsCard": {
              "runAfter": {
                "Compose_Final_Metrics": ["Succeeded"]
              },
              "type": "Compose",
              "inputs": {
                "type": "AdaptiveCard",
                "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
                "version": "1.4",
                "body": [
                  {
                    "type": "Container",
                    "style": "emphasis",
                    "items": [
                      {
                        "type": "ColumnSet",
                        "columns": [
                          {
                            "type": "Column",
                            "width": "auto",
                            "items": [
                              {
                                "type": "TextBlock",
                                "text": "🛡️",
                                "size": "ExtraLarge"
                              }
                            ]
                          },
                          {
                            "type": "Column",
                            "width": "stretch",
                            "items": [
                              {
                                "type": "TextBlock",
                                "text": "MSEM Identity Dashboard",
                                "size": "Large",
                                "weight": "Bolder"
                              },
                              {
                                "type": "TextBlock",
                                "text": "@{formatDateTime(utcNow(), 'MMMM dd, yyyy')} - Daily Security Report",
                                "size": "Small",
                                "isSubtle": true
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Container",
                    "spacing": "Medium",
                    "items": [
                      {
                        "type": "TextBlock",
                        "text": "📊 Identity Secure Score",
                        "size": "Medium",
                        "weight": "Bolder"
                      },
                      {
                        "type": "ColumnSet",
                        "columns": [
                          {
                            "type": "Column",
                            "width": "stretch",
                            "items": [
                              {
                                "type": "TextBlock",
                                "text": "**@{outputs('Calculate_Identity_Current_Score')}** pts (Identity Category)",
                                "size": "ExtraLarge",
                                "weight": "Bolder",
                                "color": "Good"
                              },
                              {
                                "type": "TextBlock",
                                "text": "Overall: @{body('Parse_SecureScore')?['value']?[0]?['currentScore']} / @{body('Parse_SecureScore')?['value']?[0]?['maxScore']} (@{formatNumber(outputs('Calculate_Score_Percentage'), 'N2')}%)",
                                "isSubtle": true,
                                "size": "Small"
                              }
                            ]
                          },
                          {
                            "type": "Column",
                            "width": "auto",
                            "items": [
                              {
                                "type": "TextBlock",
                                "text": "24h Change: @{if(greater(variables('IdentityScorePercentageChange'), 0), concat('+', formatNumber(variables('IdentityScorePercentageChange'), 'N2')), formatNumber(variables('IdentityScorePercentageChange'), 'N2'))}%",
                                "color": "@{if(greater(variables('IdentityScorePercentageChange'), 0), 'Good', if(less(variables('IdentityScorePercentageChange'), 0), 'Attention', 'Default'))}",
                                "weight": "Bolder",
                                "size": "Large"
                              },
                              {
                                "type": "TextBlock",
                                "text": "(@{if(greater(variables('ScoreChange'), 0), concat('+', string(variables('ScoreChange'))), string(variables('ScoreChange')))} pts)",
                                "isSubtle": true,
                                "size": "Small"
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Container",
                    "spacing": "Medium",
                    "items": [
                      {
                        "type": "TextBlock",
                        "text": "🎯 Risk Summary",
                        "size": "Medium",
                        "weight": "Bolder"
                      },
                      {
                        "type": "FactSet",
                        "facts": [
                          {
                            "title": "High-Risk Identities (High/Medium)",
                            "value": "@{coalesce(body('Parse_HighRiskIdentities')?['Results']?[0]?['HighRisk'], 0)}"
                          },
                          {
                            "title": "Critical (High Exposure)",
                            "value": "@{coalesce(body('Parse_HighRiskIdentities')?['Results']?[0]?['Critical'], 0)}"
                          },
                          {
                            "title": "Medium Exposure",
                            "value": "@{coalesce(body('Parse_HighRiskIdentities')?['Results']?[0]?['MediumCount'], 0)}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Container",
                    "spacing": "Medium",
                    "items": [
                      {
                        "type": "TextBlock",
                        "text": "👥 Privileged Accounts",
                        "size": "Medium",
                        "weight": "Bolder"
                      },
                      {
                        "type": "FactSet",
                        "facts": [
                          {
                            "title": "Total Privileged",
                            "value": "@{body('Parse_PrivilegedAccounts')?['Results']?[0]?['Total']}"
                          },
                          {
                            "title": "✅ Active (<30d)",
                            "value": "@{body('Parse_PrivilegedAccounts')?['Results']?[0]?['Active']}"
                          },
                          {
                            "title": "⚠️ Idle (30-90d)",
                            "value": "@{body('Parse_PrivilegedAccounts')?['Results']?[0]?['Idle']}"
                          },
                          {
                            "title": "❌ Dormant (>90d)",
                            "value": "@{body('Parse_PrivilegedAccounts')?['Results']?[0]?['Dormant']}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Container",
                    "spacing": "Medium",
                    "items": [
                      {
                        "type": "TextBlock",
                        "text": "🔐 Identity Security Status",
                        "size": "Medium",
                        "weight": "Bolder"
                      },
                      {
                        "type": "FactSet",
                        "facts": [
                          {
                            "title": "Secure Identities Rate",
                            "value": "@{body('Parse_MFAStatus')?['Results']?[0]?['SecureRate']}%"
                          },
                          {
                            "title": "Low/None Exposure",
                            "value": "@{body('Parse_MFAStatus')?['Results']?[0]?['LowOrNone']} / @{body('Parse_MFAStatus')?['Results']?[0]?['Total']}"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Container",
                    "spacing": "Medium",
                    "items": [
                      {
                        "type": "TextBlock",
                        "text": "💡 Top 3 Recommendations",
                        "size": "Medium",
                        "weight": "Bolder"
                      },
                      {
                        "type": "TextBlock",
                        "text": "**1.** @{body('Parse_Recommendations')?['value']?[0]?['title']} *(+@{body('Parse_Recommendations')?['value']?[0]?['maxScore']} pts)*",
                        "wrap": true
                      },
                      {
                        "type": "TextBlock",
                        "text": "**2.** @{body('Parse_Recommendations')?['value']?[1]?['title']} *(+@{body('Parse_Recommendations')?['value']?[1]?['maxScore']} pts)*",
                        "wrap": true
                      },
                      {
                        "type": "TextBlock",
                        "text": "**3.** @{body('Parse_Recommendations')?['value']?[2]?['title']} *(+@{body('Parse_Recommendations')?['value']?[2]?['maxScore']} pts)*",
                        "wrap": true
                      }
                    ]
                  },
                  {
                    "type": "Container",
                    "spacing": "Medium",
                    "items": [
                      {
                        "type": "TextBlock",
                        "text": "� All Recommendations",
                        "size": "Medium",
                        "weight": "Bolder"
                      },
                      {
                        "type": "TextBlock",
                        "text": "Total recommendations tracked: **@{length(body('Parse_Recommendations')?['value'])}**",
                        "wrap": true
                      },
                      {
                        "type": "TextBlock",
                        "text": "Review implementation status in the Secure Score portal for detailed progress tracking.",
                        "size": "Small",
                        "isSubtle": true,
                        "wrap": true
                      }
                    ]
                  }
                ],
                "actions": [
                  {
                    "type": "Action.OpenUrl",
                    "title": "View Full Dashboard",
                    "url": "https://security.microsoft.com/identities",
                    "style": "positive"
                  },
                  {
                    "type": "Action.OpenUrl",
                    "title": "View Recommendations",
                    "url": "https://security.microsoft.com/securescore"
                  }
                ]
              }
            },
            "Create_CSV_Content": {
              "runAfter": {
                "Compose_TeamsCard": ["Succeeded"]
              },
              "type": "Compose",
              "inputs": "@{join(createArray('Name,Identity Score Impact,Points Achieved,Status,Max Score,Implementation Cost,User Impact,Rank'), decodeUriComponent('%0A'))}@{decodeUriComponent('%0A')}@{join(select(body('Parse_Recommendations')?['value'], concat(item()?['title'], ',', if(greater(coalesce(item()?['maxScore'], 0), 0), concat('+', string(mul(div(item()?['maxScore'], 100), 2)), '%'), '-'), ',', if(greater(coalesce(item()?['implementedScore'], 0), 0), concat(string(item()?['implementedScore']), ' out of ', string(item()?['maxScore'])), concat('0 out of ', string(item()?['maxScore']))), ',', if(equals(item()?['implementedScore'], item()?['maxScore']), 'completed', 'default'), ',', string(item()?['maxScore']), ',', coalesce(item()?['implementationCost'], 'N/A'), ',', coalesce(item()?['userImpact'], 'N/A'), ',', string(item()?['rank']))), decodeUriComponent('%0A'))}"
            },
            "Send_Email_with_CSV": {
              "runAfter": {
                "Create_CSV_Content": ["Succeeded"]
              },
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['office365']['connectionId']"
                  }
                },
                "method": "post",
                "path": "/v2/Mail",
                "body": {
                  "To": "[parameters('emailRecipients')]",
                  "Subject": "MSEM Identity Dashboard - Daily Report @{formatDateTime(utcNow(), 'yyyy-MM-dd')}",
                  "Body": "<html><body><h2>🛡️ MSEM Identity Security Report</h2><p>Please find attached the daily Identity Security recommendations report.</p><h3>Summary:</h3><ul><li><strong>Identity Secure Score:</strong> @{outputs('Calculate_Identity_Current_Score')} points</li><li><strong>24h Change:</strong> @{if(greater(variables('IdentityScorePercentageChange'), 0), concat('+', formatNumber(variables('IdentityScorePercentageChange'), 'N2')), formatNumber(variables('IdentityScorePercentageChange'), 'N2'))}% (@{if(greater(variables('ScoreChange'), 0), concat('+', string(variables('ScoreChange'))), string(variables('ScoreChange')))} points)</li><li><strong>Overall Secure Score:</strong> @{body('Parse_SecureScore')?['value']?[0]?['currentScore']} / @{body('Parse_SecureScore')?['value']?[0]?['maxScore']} (@{formatNumber(outputs('Calculate_Score_Percentage'), 'N2')}%)</li><li><strong>High-Risk Identities:</strong> @{coalesce(body('Parse_HighRiskIdentities')?['Results']?[0]?['HighRisk'], 0)}</li><li><strong>Privileged Accounts:</strong> @{body('Parse_PrivilegedAccounts')?['Results']?[0]?['Total']} (Active: @{body('Parse_PrivilegedAccounts')?['Results']?[0]?['Active']}, Dormant: @{body('Parse_PrivilegedAccounts')?['Results']?[0]?['Dormant']})</li><li><strong>Secure Identities Rate:</strong> @{body('Parse_MFAStatus')?['Results']?[0]?['SecureRate']}%</li></ul><h3>Top 3 Recommendations:</h3><ol><li>@{body('Parse_Recommendations')?['value']?[0]?['title']} (+@{body('Parse_Recommendations')?['value']?[0]?['maxScore']} pts)</li><li>@{body('Parse_Recommendations')?['value']?[1]?['title']} (+@{body('Parse_Recommendations')?['value']?[1]?['maxScore']} pts)</li><li>@{body('Parse_Recommendations')?['value']?[2]?['title']} (+@{body('Parse_Recommendations')?['value']?[2]?['maxScore']} pts)</li></ol><p>See the attached CSV file for all @{length(body('Parse_Recommendations')?['value'])} recommendations.</p><p><a href='https://security.microsoft.com/securescore'>View Full Dashboard</a></p></body></html>",
                  "Importance": "Normal",
                  "Attachments": [
                    {
                      "Name": "MSEM_Identity_Recommendations_@{formatDateTime(utcNow(), 'yyyy-MM-dd')}.csv",
                      "ContentBytes": "@{base64(outputs('Create_CSV_Content'))}"
                    }
                  ]
                }
              }
            },
            "Post_Card_to_Teams": {
              "runAfter": {
                "Send_Email_with_CSV": ["Succeeded"]
              },
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['teams']['connectionId']"
                  }
                },
                "method": "post",
                "path": "/v1.0/teams/@{encodeURIComponent('TEAM_ID')}/channels/@{encodeURIComponent('CHANNEL_ID')}/messages",
                "body": {
                  "body": {
                    "contentType": "html",
                    "content": "<attachment id=\"adaptive-card\"></attachment>"
                  },
                  "attachments": [
                    {
                      "contentType": "application/vnd.microsoft.card.adaptive",
                      "content": "@{outputs('Compose_TeamsCard')}"
                    }
                  ]
                }
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "teams": {
                "connectionId": "[resourceId('Microsoft.Web/connections', parameters('teamsConnectionName'))]",
                "connectionName": "[parameters('teamsConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('logicAppLocation'), '/managedApis/teams')]"
              },
              "office365": {
                "connectionId": "[resourceId('Microsoft.Web/connections', parameters('office365ConnectionName'))]",
                "connectionName": "[parameters('office365ConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('logicAppLocation'), '/managedApis/office365')]"
              }
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', parameters('teamsConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', parameters('office365ConnectionName'))]"
      ]
    }
  ],
  "outputs": {
    "logicAppResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('logicAppName'))]",
      "metadata": {
        "description": "Resource ID of the deployed Logic App"
      }
    },
    "logicAppName": {
      "type": "string",
      "value": "[parameters('logicAppName')]",
      "metadata": {
        "description": "Name of the deployed Logic App"
      }
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('logicAppName')), '2019-05-01', 'Full').identity.principalId]",
      "metadata": {
        "description": "Principal ID of the Logic App's Managed Identity - use this to assign API permissions"
      }
    }
  }
}
